# ============================================================
# HeyGen + HyperFrames skills — environment variables (EXAMPLE)
# Copy file này thành `.env` rồi điền giá trị của bạn.
#   cp .env.example .env
# File `.env` nằm ở project root (cùng cấp với thư mục .claude/)
# và KHÔNG được commit lên git (đã có trong .gitignore).
# ============================================================

# --- HeyGen (bắt buộc cho heygen-mp3-to-mp4, heygen-script-to-mp4,
#     heygen-short-video, các pipeline mkt-full-video / knowledge-video) ---
# API key: https://app.heygen.com/settings/api
HEYGEN_API_KEY=your_heygen_api_key_here

# Pool avatar look IDs, phân cách bằng dấu phẩy (lấy từ HeyGen avatar looks)
# Ví dụ: HEYGEN_AVATAR_LOOKS=lookid1,lookid2,lookid3
HEYGEN_AVATAR_LOOKS=avatar_look_id_1,avatar_look_id_2

# Voice ID dùng cho heygen-script-to-mp4 (HeyGen TTS voice, ví dụ voice ElevenLabs đã link)
HEYGEN_VOICE_ID=

# Giới hạn độ dài video HeyGen (giây) — optional, mặc định theo skill
HEYGEN_MAX_SECONDS=

# --- ElevenLabs (bắt buộc cho mkt-elevenlabs-tts-to-mp3 / Phase 1
#     của các pipeline mkt-full-video-with-11-hyperframe-heygen*) ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
# Optional — mặc định eleven_multilingual_v2
ELEVENLABS_MODEL_ID=
# Optional — mặc định https://api.elevenlabs.io
ELEVENLABS_API_BASE=

# --- Chọn TTS provider cho 2 skill knowledge-video-heygen (9-16 / 16-9) ---
# elevenlabs (mặc định) | minimax
TTS_PROVIDER=elevenlabs

# --- MiniMax (TTS thay thế ElevenLabs — skill mkt-minimax-tts-to-mp3
#     và tts_minimax.py trong 2 skill knowledge-video-heygen) ---
# Lấy tại https://platform.minimax.io (account China: https://api.minimaxi.com)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_VOICE_ID=your_minimax_voice_id_here
# Optional — mặc định speech-02-hd; dùng speech-02-turbo nếu cần nhanh/rẻ
MINIMAX_MODEL=
# Optional — mặc định https://api.minimax.io
MINIMAX_API_BASE=

# --- OpenAI (Whisper transcribe trong hyperframes-media / talking-head pipelines) ---
OPENAI_API_KEY=

# --- Google Gemini (video understanding / một số bước phân tích) ---
GEMINI_API_KEY=
GOOGLE_API_KEY=

# --- AI33 / Grok image gen (b-roll image trong mkt-hyperframe-talking-head-video-16-9,
#     mkt-full-video-with-11-hyperframe-heygen-16-9) ---
AI33_KEY=

# --- Blotato (đăng đa nền tảng — skill mkt-blotato-publish-social) ---
# Lấy tại https://my.blotato.com → Settings → API
BLOTATO_API_KEY=your_blotato_api_key_here
